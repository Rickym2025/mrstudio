{
  "headers": [
    {
      "source": "/orbit-template(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/orbit-template",
      "destination": "/orbit-template.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
